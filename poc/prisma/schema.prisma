generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

// ============================================================
// Customer · 客户主数据（最小集合）
// 注意：master-service 仅维护各域交集字段，不存任何域内自定义配置
// ============================================================
model Customer {
  customerId       String       @id
  externalRef      String?      @unique
  name             String
  country          String?
  industry         String?
  customerType     String
  legalEntity      String?
  defaultCurrency  String?

  overallStatus    String       // INIT | IN_PROGRESS | READY | PARTIAL | CANCELLED
  templateId       String
  templateVersion  Int

  createdAt        DateTime     @default(now())
  createdBy        String?
  updatedAt        DateTime     @updatedAt
  updatedBy        String?

  tasks            ConfigTask[]
  audits           AuditLog[]

  @@index([overallStatus])
}

// ============================================================
// ConfigTask · 配置任务（只跟踪状态，不存域内配置内容）
// ============================================================
model ConfigTask {
  taskId                    Int       @id @default(autoincrement())
  customerId                String
  customer                  Customer  @relation(fields: [customerId], references: [customerId], onDelete: Cascade)

  module                    String
  taskKey                   String
  pageRef                   String?

  status                    String    // WAITING/READY/CLAIMED/IN_PROGRESS/DONE/FAILED/SKIPPED/BLOCKED/CANCELLED
  dependsOnJson             String    // JSON array of task_key strings

  // 派生快照：READY 时冻结，之后不随 min_data 变化重算
  suggestedConfigSnapshot   String?   // JSON

  // 认领信息
  claimOwner                String?
  claimedAt                 DateTime?
  claimTimeoutAt            DateTime?

  // 重试 / 失败
  retryCount                Int       @default(0)
  lastErrorCode             String?
  lastErrorMsg              String?

  // 时间戳
  createdAt                 DateTime  @default(now())
  readyAt                   DateTime?
  startedAt                 DateTime?
  completedAt               DateTime?

  @@unique([customerId, taskKey])    // 幂等关键约束
  @@index([customerId, status])
  @@index([module, status])
}

// ============================================================
// ConfigTemplate · 模板（按 customer_type 分，可版本化）
// ============================================================
model ConfigTemplate {
  templateId    String
  version       Int
  customerType  String
  definition    String      // JSON 字符串：modules → tasks → suggestions
  isActive      Boolean     @default(false)
  createdAt     DateTime    @default(now())

  @@id([templateId, version])
  @@index([customerType, isActive])
}

// ============================================================
// LookupTable · 字典（${lookup.X[...]} 表达式引用）
// ============================================================
model LookupTable {
  name        String   @id
  version     Int
  entries     String   // JSON
  description String?
  updatedAt   DateTime @updatedAt
  updatedBy   String?
}

// ============================================================
// AuditLog · 审计日志（不可篡改的状态迁移记录）
// ============================================================
model AuditLog {
  id          Int       @id @default(autoincrement())
  customerId  String?
  customer    Customer? @relation(fields: [customerId], references: [customerId], onDelete: Cascade)
  taskId      Int?
  eventType   String    // task_state_change | customer_create | template_apply
  fromStatus  String?
  toStatus    String?
  actor       String?   // system | user:xxx | downstream:sales-pod-7
  reason      String?
  extra       String?   // JSON 任意附加上下文
  createdAt   DateTime  @default(now())

  @@index([taskId, createdAt])
  @@index([customerId, createdAt])
}

// ============================================================
// Counter · 用于生成有序、无冲突的 customer_id 等序列号
// （SQLite + Prisma 不支持原生 sequence，用一行 upsert+increment 模拟）
// ============================================================
model Counter {
  name   String @id   // e.g. "customer_seq"
  value  Int    @default(0)
}
