generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

// ============================================================
// Customer · 客户主数据（最小集合）
// 仅维护各域交集字段，不存任何域内自定义配置
// ============================================================
model Customer {
  customerId       String              @id  // 内部 PK，自增 "C0001"

  // 用户填入的最小集合
  custNo           String              @unique @map("cust_no")
  custName         String              @map("cust_name")
  globalCustNo     String?             @map("global_cust_no")
  globalCustName   String?             @map("global_cust_name")
  globalCustCode   String?             @map("global_cust_code")
  regionNo         String?             @map("region_no")
  companyNo        String?             @map("company_no")
  isMaster         Boolean             @default(false) @map("is_master")
  isInterCompany   Boolean             @default(false) @map("is_inter_company")

  externalRef      String?             @unique

  // 内部：模板选择键（默认；POC 暂只有 standard_b2b）
  customerType     String              @default("standard_b2b")

  // 整体状态
  overallStatus    String
  templateId       String
  templateVersion  Int

  // 元信息
  createdAt        DateTime            @default(now())
  createdBy        String?
  updatedAt        DateTime            @updatedAt
  updatedBy        String?

  tasks            ConfigTask[]
  audits           AuditLog[]
  locations        CustomerLocation[]

  @@index([overallStatus])
}

// ============================================================
// CustomerLocation · 客户 × 域 × 位置号（一对多）
// 每个 (customerId, domain) 至多一条
// 例: { customerId: "C0001", domain: "sales",   locNo: "LOC-SLS-001" }
//     { customerId: "C0001", domain: "mfg",     locNo: "LOC-MFG-001" }
// ============================================================
model CustomerLocation {
  id          Int      @id @default(autoincrement())
  customerId  String
  customer    Customer @relation(fields: [customerId], references: [customerId], onDelete: Cascade)
  domain      String   // 'mfg' / 'sales' / 'crm' / 'finance' / 'plm' / ...
  locNo       String   @map("loc_no")
  createdAt   DateTime @default(now())

  @@unique([customerId, domain])
  @@index([customerId])
}

// ============================================================
// ConfigTask · 配置任务（只跟踪状态，不存域内配置内容）
// ============================================================
model ConfigTask {
  taskId                    Int       @id @default(autoincrement())
  customerId                String
  customer                  Customer  @relation(fields: [customerId], references: [customerId], onDelete: Cascade)

  module                    String
  taskKey                   String
  pageRef                   String?

  status                    String
  dependsOnJson             String

  suggestedConfigSnapshot   String?

  claimOwner                String?
  claimedAt                 DateTime?
  claimTimeoutAt            DateTime?

  retryCount                Int       @default(0)
  lastErrorCode             String?
  lastErrorMsg              String?

  createdAt                 DateTime  @default(now())
  readyAt                   DateTime?
  startedAt                 DateTime?
  completedAt               DateTime?

  @@unique([customerId, taskKey])
  @@index([customerId, status])
  @@index([module, status])
}

// ============================================================
// ConfigTemplate · 模板
// ============================================================
model ConfigTemplate {
  templateId    String
  version       Int
  customerType  String
  definition    String
  isActive      Boolean     @default(false)
  createdAt     DateTime    @default(now())

  @@id([templateId, version])
  @@index([customerType, isActive])
}

// ============================================================
// LookupTable · 字典
// ============================================================
model LookupTable {
  name        String   @id
  version     Int
  entries     String
  description String?
  updatedAt   DateTime @updatedAt
  updatedBy   String?
}

// ============================================================
// AuditLog · 审计
// ============================================================
model AuditLog {
  id          Int       @id @default(autoincrement())
  customerId  String?
  customer    Customer? @relation(fields: [customerId], references: [customerId], onDelete: Cascade)
  taskId      Int?
  eventType   String
  fromStatus  String?
  toStatus    String?
  actor       String?
  reason      String?
  extra       String?
  createdAt   DateTime  @default(now())

  @@index([taskId, createdAt])
  @@index([customerId, createdAt])
}

// ============================================================
// Counter · 用于生成有序、无冲突的 customer_id 等序列号
// ============================================================
model Counter {
  name   String @id
  value  Int    @default(0)
}
